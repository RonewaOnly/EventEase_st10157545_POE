@model EventEase_st10157545_POE.Models.Booking
@{
    ViewData["Title"] = "Delete Booking";
}

<div class="page-header">
    <h1>Delete Booking #@Model.BookingID</h1>
</div>

<div class="card" style="max-width:560px">
    <div class="card-body">
        <p style="margin-bottom:16px">Are you sure you want to permanently delete this booking? This action cannot be undone.</p>
        <table style="width:100%;font-size:14px;margin-bottom:20px">
            <tr><td class="text-muted" style="padding:5px 0;width:40%">Customer</td><td>@Model.Customer?.FullName</td></tr>
            <tr><td class="text-muted" style="padding:5px 0">Venue</td><td>@Model.Venue?.VenueName</td></tr>
            <tr><td class="text-muted" style="padding:5px 0">Event Date</td><td>@Model.EventDate.ToString("dd MMM yyyy")</td></tr>
            <tr><td class="text-muted" style="padding:5px 0">Status</td><td><span class="badge badge-@Model.Status.ToLower()">@Model.Status</span></td></tr>
        </table>
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <div class="btn-group">
                <button type="submit" class="btn btn-danger">Yes, Delete</button>
                <a asp-action="Details" asp-route-id="@Model.BookingID" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

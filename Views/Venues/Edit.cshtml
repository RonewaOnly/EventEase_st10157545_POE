    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model EventEase_st10157545_POE.Models.VenueViewModel
@{
    ViewData["Title"] = "Edit Venue";
}


<div class="page-header">
    <h1>Edit Venue</h1>
    <a asp-action="Index" class="btn btn-secondary">← Back</a>
</div>


<div class="card" style="max-width:720px">
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="VenueID" />
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="VenueName"></label>
                    <input asp-for="VenueName" class="form-control" />
                    <span asp-validation-for="VenueName" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Location"></label>
                    <input asp-for="Location" class="form-control" />
                    <span asp-validation-for="Location" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Capacity"></label>
                    <input asp-for="Capacity" type="number" min="1" class="form-control" />
                    <span asp-validation-for="Capacity" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="PricePerDay"></label>
                    <input asp-for="PricePerDay" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="PricePerDay" class="field-validation-error"></span>
                </div>


                <!-- Current image display -->
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="form-group full">
                        <label>Current Image</label>
                        <div style="margin-top:6px">
                            <img src="@Model.ImageUrl" alt="Current venue image" class="img-preview" />
                        </div>
                    </div>
                }


                <!-- Image upload — leave blank to keep existing -->
                <div class="form-group full">
                    <label asp-for="ImageFile"></label>
                    <input asp-for="ImageFile" type="file" accept="image/jpeg,image/png,image/gif,image/webp"
                           class="form-control" onchange="previewImage(this,'venuePreview')" />
                    <small class="text-muted">Upload a new image to replace the current one. Leave blank to keep existing.</small>
                    <span asp-validation-for="ImageFile" class="field-validation-error"></span>
                    <div id="venuePreview" class="img-preview-wrap" style="display:none;margin-top:10px">
                        <img id="venuePreviewImg" src="" alt="New image preview" class="img-preview" />
                    </div>
                </div>


                <!-- Keep the stored URL so it isn't wiped when no new file is chosen -->
                <input type="hidden" asp-for="ImageUrl" />


                <div class="form-group full">
                    <label asp-for="Description"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                </div>
                <div class="form-group">
                    <label class="checkbox-label">
                        <input asp-for="IsActive" type="checkbox" /> Active
                    </label>
                </div>
            </div>
            <div class="btn-group mt-4">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Details" asp-route-id="@Model.VenueID" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    <script>
        function previewImage(input, previewId) {
            const wrap = document.getElementById(previewId);
            const img  = document.getElementById(previewId + 'Img');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => { img.src = e.target.result; wrap.style.display = 'block'; };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}


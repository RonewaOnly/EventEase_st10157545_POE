@model EventEase_st10157545_POE.Models.CustomerViewModel
@{
    ViewData["Title"] = Model.FullName;
}

<div class="page-header">
    <div>
        <h1>@Model.FullName</h1>
        <p>Customer since @Model.CreateAt.ToString("dd MMM yyyy")</p>
    </div>
    <div class="btn-group">
        <a asp-action="Edit" asp-route-id="@Model.CustomerID" class="btn btn-secondary">Edit</a>
        <a asp-controller="Bookings" asp-action="Create" class="btn btn-primary">+ New Booking</a>
        <a asp-action="Index" class="btn btn-secondary">← Back</a>
    </div>
</div>

<div class="two-col">
    <div class="card" style="align-self:start">
        <div class="card-header"><h2>Contact Info</h2></div>
        <div class="card-body">
            <table style="width:100%;font-size:14px">
                <tr><td class="text-muted" style="padding:6px 0;width:35%">Email</td><td>@Model.Email</td></tr>
                <tr><td class="text-muted" style="padding:6px 0">Phone</td><td>@Model.phoneNumber/td></tr>
                <tr><td class="text-muted" style="padding:6px 0">Bookings</td><td>@Model.Bookings.Count total</td></tr>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><h2>Booking History</h2></div>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr><th>#</th><th>Event</th><th>Venue</th><th>Date</th><th>Status</th></tr>
                </thead>
                <tbody>
                    @if (!Model.Bookings.Any())
                    {
                        <tr><td colspan="5" class="text-muted" style="padding:20px">No bookings yet.</td></tr>
                    }
                    @foreach (var b in Model.Bookings.OrderByDescending(b => b.EventDate))
                    {
                        <tr>
                            <td><a asp-controller="Bookings" asp-action="Details" asp-route-id="@b.BookingID">#@b.BookingID</a></td>
                            <td>@b.Event?.EventName</td>
                            <td>@b.Venue?.VenueName</td>
                            <td>@b.EventDate.ToString("dd MMM yyyy")</td>
                            <td><span class="badge badge-@b.Status.ToLower()">@b.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

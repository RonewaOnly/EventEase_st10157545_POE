@model EventEase_st10157545_POE.Models.CustomerViewModel
@{
    ViewData["Title"] = "Delete Customer";
}

<div class="page-header">
    <h1>Delete Customer</h1>
</div>

<div class="card" style="max-width:500px">
    <div class="card-body">
        <p style="margin-bottom:16px">Are you sure you want to delete this customer? Their booking records will also be affected.</p>
        <table style="width:100%;font-size:14px;margin-bottom:20px">
            <tr><td class="text-muted" style="padding:5px 0;width:40%">Name</td><td>@Model.FullName</td></tr>
            <tr><td class="text-muted" style="padding:5px 0">Email</td><td>@Model.Email</td></tr>
            <tr><td class="text-muted" style="padding:5px 0">Phone</td><td>@Model.phoneNumber</td></tr>
        </table>
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <div class="btn-group">
                <button type="submit" class="btn btn-danger">Yes, Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

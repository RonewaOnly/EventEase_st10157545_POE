@model EventEase_st10157545_POE.Models.EventType
@{
    ViewData["Title"] = "Add Event Type";
}

<div class="page-header">
    <h1>Add Event Type</h1>
    <a asp-action="EventTypes" class="btn btn-secondary">← Back to Event Types</a>
</div>

<div class="card" style="max-width:540px">
    <div class="card-body">
        <form asp-action="CreateEventType" method="post">
            @Html.AntiForgeryToken()
            <div class="form-grid">
                <div class="form-group full">
                    <label asp-for="TypeName"></label>
                    <input asp-for="TypeName" class="form-control" placeholder="e.g. Engagement Party" />
                    <span asp-validation-for="TypeName" class="field-validation-error"></span>
                </div>
                <div class="form-group full">
                    <label asp-for="Description"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"
                              placeholder="Short description of this event category"></textarea>
                </div>
                <div class="form-group">
                    <label class="checkbox-label">
                        <input asp-for="IsActive" type="checkbox" /> Active
                    </label>
                </div>
            </div>
            <div class="btn-group mt-4">
                <button type="submit" class="btn btn-primary">Save Event Type</button>
                <a asp-action="EventTypes" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

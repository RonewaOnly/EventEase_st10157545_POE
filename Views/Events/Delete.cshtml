    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model EventEase_st10157545_POE.Models.EventViewModel
@{
    ViewData["Title"] = "Delete Event";
}


<div class="page-header">
    <h1>Delete Event</h1>
</div>


@if (ViewData["ActiveBookingWarning"] != null)
{
    <div class="conflict-alert" style="margin-bottom:16px">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor" style="flex-shrink:0;margin-top:2px">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75
                1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1
                1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
                  clip-rule="evenodd" />
        </svg>
        <div>
            <strong>Cannot delete this event.</strong><br />
            @ViewData["ActiveBookingWarning"]
            Go to <a asp-controller="Bookings" asp-action="Index">Bookings</a> and cancel all
            bookings for this event first, then return here to delete it.
        </div>
    </div>
    <a asp-action="Index" class="btn btn-secondary">← Back to Events</a>
}
else
{
    <div class="card" style="max-width:520px">
        <div class="card-body">
            <p style="margin-bottom:16px">
                Are you sure you want to permanently delete this event?
                Its image will also be removed from Azure Blob Storage. This cannot be undone.
            </p>
            <table style="width:100%;font-size:14px;margin-bottom:20px">
                <tr><td class="text-muted" style="padding:5px 0;width:40%">Event Name</td><td>@Model.EventName</td></tr>
                <tr>
                    <td class="text-muted" style="padding:5px 0">Status</td>
                    <td><span class="badge badge-@Model.Status.ToLower()">@Model.Status</span></td>
                </tr>
                <tr>
                    <td class="text-muted" style="padding:5px 0">Preferred Date</td>
                    <td>@(Model.PreferredDate?.ToString("dd MMM yyyy") ?? "—")</td>
                </tr>
            </table>
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <div class="btn-group">
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
}


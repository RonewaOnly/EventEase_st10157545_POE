@model EventEase_st10157545_POE.Models.EventViewModel
@{
    ViewData["Title"] = "Delete Event";
}

<div class="page-header">
    <h1>Delete Event</h1>
</div>

<div class="card" style="max-width:500px">
    <div class="card-body">
        <p style="margin-bottom:16px">Are you sure you want to delete this event? Any linked bookings will lose their event reference.</p>
        <table style="width:100%;font-size:14px;margin-bottom:20px">
            <tr><td class="text-muted" style="padding:5px 0;width:40%">Event Name</td><td>@Model.EventName</td></tr>
            <tr><td class="text-muted" style="padding:5px 0">Status</td><td><span class="badge badge-@Model.Status.ToLower()">@Model.Status</span></td></tr>
            <tr><td class="text-muted" style="padding:5px 0">Preferred Date</td><td>@(Model.PreferredDate?.ToString("dd MMM yyyy") ?? "—")</td></tr>
        </table>
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <div class="btn-group">
                <button type="submit" class="btn btn-danger">Yes, Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

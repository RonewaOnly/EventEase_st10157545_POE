@{
    ViewData["Title"] = "Access Denied";
}

<div class="page-header">
    <h1>Access Denied</h1>
</div>

<div class="card" style="max-width:520px">
    <div class="card-body" style="text-align:center;padding:40px 32px">
        <!-- Lock icon -->
        <div style="margin-bottom:20px">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--clr-danger)" stroke-width="1.5"
                 width="52" height="52" style="opacity:0.7">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0110 0v4" />
            </svg>
        </div>
        <h2 style="font-size:18px;margin-bottom:8px">Admin access required</h2>
        <p style="font-size:14px;color:var(--clr-text-muted);margin-bottom:24px;line-height:1.6">
            This area is restricted to Admin accounts.<br>
            If you need access, contact your system administrator.
        </p>
        <div class="btn-group" style="justify-content:center">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Back to Dashboard</a>
            <a asp-controller="Account" asp-action="Profile" class="btn btn-secondary">My Profile</a>
        </div>
    </div>
</div>

